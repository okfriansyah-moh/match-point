# ═══════════════════════════════════════════════════════════════════════════════
# Match Point — monorepo .gitignore
# Go backend · Vue / React / Svelte frontend · tooling · AI artefacts
# ═══════════════════════════════════════════════════════════════════════════════

# ── OS & filesystem junk ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.fuse_hidden*
.directory
.Trash-*

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json

# ── Logs & temp ─────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# ═══════════════════════════════════════════════════════════════════════════════
# Go (backend/)
# ═══════════════════════════════════════════════════════════════════════════════
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
backend/bin/
backend/dist/
backend/build/
/backend/main
/backend/cmd/**/main
**/__debug_bin*

# Test & coverage
*.test
*.out
coverage.out
coverage.html
coverage.xml
*.coverprofile
backend/coverage/

# Go workspace / vendor (uncomment vendor/ if you commit deps)
go.work
go.work.sum
# vendor/

# Air / live-reload
backend/tmp/
.air.toml.bak

# Delve
__debug_bin

# ═══════════════════════════════════════════════════════════════════════════════
# Node / frontend (frontend/ or packages/*)
# ═══════════════════════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Package manager locks (keep one; ignore others if you standardize on npm)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build outputs
dist/
build/
out/
.output/
.nuxt/
.next/
.svelte-kit/
.vercel/
.netlify/
.wrangler/
.open-next/
storybook-static/
*.tsbuildinfo

# Vite
frontend/.vite/
**/.vite/

# Vue
*.local
frontend/.vuepress/dist/

# React (CRA, Next, Remix)
frontend/.next/
frontend/.cache/
frontend/coverage/
.eslintcache
.stylelintcache

# Svelte / SvelteKit
frontend/.svelte-kit/
frontend/package/

# Vitest / Jest / Playwright / Cypress
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
blob-report/

# Turbo / Nx monorepo
.turbo/
.nx/cache/

# ═══════════════════════════════════════════════════════════════════════════════
# IDEs & editors
# ═══════════════════════════════════════════════════════════════════════════════
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
!.vscode/launch.json.example
!.vscode/tasks.json.example
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.code-workspace

# Cursor
.cursor/
!.cursor/rules/
!.cursor/skills/
!.cursor/skills-cursor/

# JetBrains
*.sw?

# ═══════════════════════════════════════════════════════════════════════════════
# AI / agent artefacts (do not commit generated junk)
# ═══════════════════════════════════════════════════════════════════════════════
# Cursor / Copilot / generic
*.cursor-plan
.cursorignore.local
.copilot/
.github/copilot/

# Claude / Anthropic
.claude/
.claude-cache/
*.claude.md.bak

# OpenAI / ChatGPT exports
chatgpt-exports/
.openai/

# Windsurf / Codeium / Tabnine / Continue
.windsurf/
.codeium/
.continue/

# Agent transcripts & scratch (local only)
agent-transcripts/
*.agent.md
scratch/
.scratch/
prompts/local/
*.prompt.bak

# Generated docs / plans (optional — uncomment if you never want these tracked)
# *_plan*.md
# *_architecture*.md
# AGENT-PROMPT.md

# AI-generated assets dumps
generated/
ai-output/
*.generated.*

# ═══════════════════════════════════════════════════════════════════════════════
# Docker & infra (local overrides only)
# ═══════════════════════════════════════════════════════════════════════════════
docker-compose.override.yml
docker-compose.*.local.yml
*.local.yml

# Terraform (if added later)
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# ═══════════════════════════════════════════════════════════════════════════════
# Databases & local data
# ═══════════════════════════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
*.db-journal
postgres-data/
pgdata/
redis-data/
data/local/
uploads/local/

# ═══════════════════════════════════════════════════════════════════════════════
# Misc tooling
# ═══════════════════════════════════════════════════════════════════════════════
.direnv/
.envrc.local
*.orig
*.rej
.sass-cache/
.parcel-cache/
.turbo/
server.pid
*.pid
